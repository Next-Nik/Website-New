{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/integrity-cron",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/indicator-cron",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/compute-daily-snapshot",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/compute-effort-signal",
      "schedule": "45 3 * * *"
    }
  ],
  "functions": {
    "api/integrity-cron.js": {
      "maxDuration": 60
    },
    "api/indicator-cron.js": {
      "maxDuration": 60
    },
    "api/indicator-worker.js": {
      "maxDuration": 60
    },
    "api/compute-daily-snapshot.js": {
      "maxDuration": 30
    },
    "api/compute-effort-signal.js": {
      "maxDuration": 30
    },
    "api/nextus-match.js": {
      "maxDuration": 15
    },
    "api/org-extract.js": {
      "maxDuration": 60
    },
    "api/map-chat.js": {
      "maxDuration": 60
    },
    "api/map-avatar-chat.js": {
      "maxDuration": 60
    },
    "api/map-scoring-chat.js": {
      "maxDuration": 60
    },
    "api/map-synthesis-chat.js": {
      "maxDuration": 60
    },
    "api/connection-synthesis-chat.js": {
      "maxDuration": 60
    },
    "api/orienteering-chat.js": {
      "maxDuration": 60
    },
    "api/nextsteps-chat.js": {
      "maxDuration": 60
    },
    "api/nextsteps-track.js": {
      "maxDuration": 15
    },
    "api/nextsteps-path.js": {
      "maxDuration": 60
    },
    "api/nextsteps-actors-sample.js": {
      "maxDuration": 15
    },
    "api/nextsteps-tag-actor.js": {
      "maxDuration": 300
    },
    "api/horizon-state-chat.js": {
      "maxDuration": 60
    },
    "api/purpose-piece-chat.js": {
      "maxDuration": 60
    },
    "api/purpose-piece-chat-deep.js": {
      "maxDuration": 60
    },
    "api/target-sprint-chat.js": {
      "maxDuration": 60
    },
    "api/target-sprint-coach-chat.js": {
      "maxDuration": 60
    },
    "api/debrief-chat.js": {
      "maxDuration": 60
    },
    "api/horizon-practice-setup-chat.js": {
      "maxDuration": 60
    },
    "api/horizon-practice-daily-chat.js": {
      "maxDuration": 60
    },
    "api/horizon-practice-loop-chat.js": {
      "maxDuration": 60
    },
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/create-checkout.js": {
      "maxDuration": 15
    },
    "api/podcast-feed.js": {
      "maxDuration": 15
    },
    "api/ical-proxy.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/tools/north-star/api/chat",
      "destination": "/api/orienteering-chat"
    },
    {
      "source": "/tools/nextsteps/api/chat",
      "destination": "/api/nextsteps-chat"
    },
    {
      "source": "/api/nextsteps-track",
      "destination": "/api/nextsteps-track"
    },
    {
      "source": "/api/nextsteps-path",
      "destination": "/api/nextsteps-path"
    },
    {
      "source": "/api/nextsteps-actors-sample",
      "destination": "/api/nextsteps-actors-sample"
    },
    {
      "source": "/api/nextsteps-tag-actor",
      "destination": "/api/nextsteps-tag-actor"
    },
    {
      "source": "/tools/map/api/chat",
      "destination": "/api/map-chat"
    },
    {
      "source": "/tools/map/api/avatar-chat",
      "destination": "/api/map-avatar-chat"
    },
    {
      "source": "/tools/map/api/connection-synthesis",
      "destination": "/api/connection-synthesis-chat"
    },
    {
      "source": "/api/map-scoring-chat",
      "destination": "/api/map-scoring-chat"
    },
    {
      "source": "/api/map-synthesis-chat",
      "destination": "/api/map-synthesis-chat"
    },
    {
      "source": "/tools/horizon-state/api/chat",
      "destination": "/api/horizon-state-chat"
    },
    {
      "source": "/tools/purpose-piece/api/chat",
      "destination": "/api/purpose-piece-chat"
    },
    {
      "source": "/tools/purpose-piece/api/chat-deep",
      "destination": "/api/purpose-piece-chat-deep"
    },
    {
      "source": "/tools/target-sprint/api/chat",
      "destination": "/api/target-sprint-chat"
    },
    {
      "source": "/tools/target-sprint/api/sprint-coach",
      "destination": "/api/target-sprint-coach-chat"
    },
    {
      "source": "/tools/horizon-practice/api/setup-chat",
      "destination": "/api/horizon-practice-setup-chat"
    },
    {
      "source": "/tools/horizon-practice/api/daily-chat",
      "destination": "/api/horizon-practice-daily-chat"
    },
    {
      "source": "/tools/horizon-practice/api/loop-chat",
      "destination": "/api/horizon-practice-loop-chat"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe-webhook"
    },
    {
      "source": "/api/create-checkout",
      "destination": "/api/create-checkout"
    },
    {
      "source": "/api/nextus-match",
      "destination": "/api/nextus-match"
    },
    {
      "source": "/api/org-extract",
      "destination": "/api/org-extract"
    },
    {
      "source": "/api/debrief-chat",
      "destination": "/api/debrief-chat"
    },
    {
      "source": "/api/integrity-cron",
      "destination": "/api/integrity-cron"
    },
    {
      "source": "/api/compute-daily-snapshot",
      "destination": "/api/compute-daily-snapshot"
    },
    {
      "source": "/api/compute-effort-signal",
      "destination": "/api/compute-effort-signal"
    },
    {
      "source": "/api/podcast-feed",
      "destination": "/api/podcast-feed"
    },
    {
      "source": "/api/ical-proxy",
      "destination": "/api/ical-proxy"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
