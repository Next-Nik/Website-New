{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/map-chat.js": {
      "maxDuration": 60
    },
    "api/orienteering-chat.js": {
      "maxDuration": 60
    },
    "api/purpose-piece-chat.js": {
      "maxDuration": 60
    },
    "api/purpose-piece-chat-deep.js": {
      "maxDuration": 60
    },
    "api/target-goals-chat.js": {
      "maxDuration": 60
    },
    "api/map-avatar-chat.js": {
      "maxDuration": 60
    },
    "api/foundation-review-chat.js": {
      "maxDuration": 60
    },
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/expansion-setup-chat.js": {
      "maxDuration": 60
    },
    "api/expansion-daily-chat.js": {
      "maxDuration": 60
    },
    "api/expansion-loop-chat.js": {
      "maxDuration": 60
    },
    "api/connection-synthesis-chat.js": {
      "maxDuration": 60
    },
    "api/map-scoring-chat.js": {
      "maxDuration": 60
    },
    "api/map-synthesis-chat.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/tools/map/api/chat",
      "destination": "/api/map-chat"
    },
    {
      "source": "/tools/map/api/avatar-chat",
      "destination": "/api/map-avatar-chat"
    },
    {
      "source": "/api/map-scoring-chat",
      "destination": "/api/map-scoring-chat"
    },
    {
      "source": "/api/map-synthesis-chat",
      "destination": "/api/map-synthesis-chat"
    },
    {
      "source": "/tools/orienteering/api/chat",
      "destination": "/api/orienteering-chat"
    },
    {
      "source": "/tools/purpose-piece/api/chat",
      "destination": "/api/purpose-piece-chat"
    },
    {
      "source": "/tools/purpose-piece/api/chat-deep",
      "destination": "/api/purpose-piece-chat-deep"
    },
    {
      "source": "/tools/target-goals/api/chat",
      "destination": "/api/target-goals-chat"
    },
    {
      "source": "/tools/foundation/api/review",
      "destination": "/api/foundation-review-chat"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe-webhook"
    },
    {
      "source": "/tools/expansion/api/setup-chat",
      "destination": "/api/expansion-setup-chat"
    },
    {
      "source": "/tools/expansion/api/daily-chat",
      "destination": "/api/expansion-daily-chat"
    },
    {
      "source": "/tools/expansion/api/loop-chat",
      "destination": "/api/expansion-loop-chat"
    },
    {
      "source": "/tools/map/api/connection-synthesis",
      "destination": "/api/connection-synthesis-chat"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}